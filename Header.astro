---
// No deberías poner nada más que la configuración de Astro aquí, por ejemplo:
// title, description, etc.
import Layout from "../layouts/Layout.astro";
import { links } from "../data/links.js"; // Si los enlaces son dinámicos, puedes importarlos así.
---

<header class="bg-gray-800 py-4">
  <nav class="container mx-auto flex justify-center space-x-6">
    {links.map(link => (
      <a href={link.url} class="text-blue-400 hover:underline">{link.name}</a>
    ))}
  </nav>
</header>


