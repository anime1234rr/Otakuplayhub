---
import Layout from "../layouts/Layout.astro";
import Juego from "../components/Juego.astro"; // Importa el componente para juegos
import Anime from "../components/Anime.astro"; // Importa el componente para anime
---

<Layout title="Juegos - OtakuPlayhub">
  <section class="text-center py-10">
    <h1 class="text-4xl font-bold">Juegos</h1>
    <p class="mt-4 text-lg">¡Juegos de la comunidad!</p>
  </section>

  <div class="grid grid-cols-3 gap-4">
    <Juego 
      imagen="/images/super-mario-bros.jpg" 
      titulo="Super Mario Bros." 
      link="/juegos/super-mario-bros" 
    />
    <Juego 
      imagen="/images/otro-juego.jpg" 
      titulo="Otro Juego" 
      link="/juegos/otro-juego" 
    />
    <!-- Repite este componente para cada juego -->
  </div>
</Layout>
